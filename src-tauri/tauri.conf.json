{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lazypub",
  "version": "0.1.5",
  "identifier": "com.x1nx3r.lazypub",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lazypub",
        "width": 1400,
        "height": 900,
        "decorations": false,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: 'unsafe-inline' 'unsafe-eval' http://localhost:*; img-src 'self' blob: data: tauri: http://localhost:*; frame-src 'self' blob: data:; child-src 'self' blob: data:; style-src 'self' 'unsafe-inline' tauri: http://localhost:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
